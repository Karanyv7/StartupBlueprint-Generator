# ============================================================
#  IBM watsonx.ai — Innovation Blueprint Agent
#  Copy this file to .env and fill in your credentials
# ============================================================

# IBM Cloud API Key (required)
IBM_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai Project ID (required)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai URL (default: Dallas region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite Model ID
WATSONX_MODEL_ID=ibm/granite-3-3-8b-instruct

# Flask secret key (change this to a strong random string in production)
FLASK_SECRET_KEY=change-me-to-a-long-random-secret-key

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=True

# App port
PORT=5000
